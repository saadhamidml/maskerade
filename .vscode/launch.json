                "--force",
                "with",
                "configs/mauna_loa/bq.yaml"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "af-bq",
            "type": "python",
            "request": "launch",
            "cwd": "${workspaceFolder}/src",
            "program": "${workspaceFolder}/src/main.py",
            "args": [
                "--force",
                "with",
                "configs/airfoil/bq.yaml"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
